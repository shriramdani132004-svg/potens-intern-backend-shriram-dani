generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id            Int      @id @default(autoincrement())

  actor         String

  action        String

  payload       Json

  previousHash  String?

  currentHash   String

  createdAt     DateTime @default(now())
}